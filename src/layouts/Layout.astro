---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	canonicalURL?: string;
}

const {
	title = "Samsun Sıhhi Tesisat | Kombi Bakım | Su Kaçağı Tespiti | Renaz Teknik",
	description = "Renaz Teknik - Samsun'da profesyonel sıhhi tesisat hizmetleri. Kombi bakım, petek temizliği, su kaçağı tespiti, tıkanıklık açma, banyo-mutfak tadilat. İlkadım, Atakum, Canik'te 7/24 hizmet.",
	keywords = "Samsun tesisat, Samsun kombi bakım, su kaçağı tespiti Samsun, İlkadım tesisat, Atakum tesisatçı, Canik tesisat, Samsun banyo tadilat, mutfak tamirat Samsun, renaz teknik",
	canonicalURL = Astro.url.href,
} = Astro.props;

const siteURL = "https://renazteknik.com";
const fullTitle = title.includes("renazteknik.com") ? title : `${title} | renazteknik.com`;
---

<!doctype html>
<html lang="tr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/icon.svg" />
		<link rel="apple-touch-icon" href="/icon.svg" />
		
		<!-- Primary Meta Tags -->
		<title>{fullTitle}</title>
		<meta name="title" content={fullTitle} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content="Renaz Teknik" />
		<meta name="robots" content="index, follow" />
		<meta name="language" content="Turkish" />
		<meta name="revisit-after" content="7 days" />
		<link rel="canonical" href={canonicalURL} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Renaz Teknik" />
		<meta property="og:locale" content="tr_TR" />
		<meta property="og:image" content={`${siteURL}/og-image.jpg`} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={description} />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={`${siteURL}/og-image.jpg`} />
		
		<!-- Additional Meta Tags -->
		<meta name="theme-color" content="#fad000" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@300;400;700&display=swap" rel="stylesheet" />
		
		<!-- Enhanced Structured Data (JSON-LD) -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"name": "Renaz Teknik",
			"image": `${siteURL}/icon.svg`,
			"@id": siteURL,
			"url": siteURL,
			"telephone": "+905346706294",
			"priceRange": "$$",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "ZAFER MAH. INCE SK. BIRLIK APARTMANI NO: 56 A IÇ KAPI NO: 1",
				"addressLocality": "ILKADIM",
				"addressRegion": "SAMSUN",
				"addressCountry": "TR"
			},
			"geo": {
				"@type": "GeoCoordinates",
				"latitude": "41.2867",
				"longitude": "36.3300"
			},
			"openingHoursSpecification": [
				{
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
					"opens": "08:00",
					"closes": "18:00"
				}
			],
			"sameAs": [
				"https://wa.me/905346706294"
			],
			"description": description,
			"areaServed": [
				{
					"@type": "City",
					"name": "Samsun"
				},
				{
					"@type": "City",
					"name": "İlkadım"
				},
				{
					"@type": "City",
					"name": "Atakum"
				},
				{
					"@type": "City",
					"name": "Canik"
				},
				{
					"@type": "City",
					"name": "Tekkeköy"
				}
			],
			"hasOfferCatalog": {
				"@type": "OfferCatalog",
				"name": "Sıhhi Tesisat Hizmetleri",
				"itemListElement": [
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Sıhhi Tesisat Çözümleri",
							"serviceType": "Plumbing Service",
							"description": "Ev ve iş yerlerinizdeki tüm sıhhi tesisat ihtiyaçlarını profesyonel ekip ve modern ekipmanlarla çözüyoruz."
						}
					},
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Kombi Bakım ve Arıza Çözümleri",
							"serviceType": "Boiler Maintenance",
							"description": "Kombi performansını artıran detaylı bakım işlemleri ve tüm marka-model kombiler için arıza tespiti."
						}
					},
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Petek Temizliği",
							"serviceType": "Radiator Cleaning",
							"description": "Kombi ve petek verimini yükselten profesyonel makinelerle petek temizliği."
						}
					},
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Tıkanıklık Açma",
							"serviceType": "Drain Cleaning",
							"description": "Gider, banyo, lavabo, tuvalet tıkanıklıklarını kameralı sistemler ve profesyonel makinelerle açıyoruz."
						}
					},
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Su Kaçağı Tespiti",
							"serviceType": "Leak Detection",
							"description": "Duvar veya zemin kırmadan, akustik dinleme ve termal kamera ile su kaçaklarını tespit ediyoruz."
						}
					},
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Batarya, Musluk, Klozet Tamir & Değişimi",
							"serviceType": "Faucet and Toilet Repair",
							"description": "Su kaçıran musluklar, bozuk sifonlar, klozet arızaları gibi günlük tesisat sorunlarını hızlı şekilde çözüyoruz."
						}
					},
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Banyo & Mutfak Yenileme (Tadilat)",
							"serviceType": "Bathroom and Kitchen Renovation",
							"description": "Eskiyen banyo ve mutfaklarınızı modern, kullanışlı ve estetik bir alana dönüştürüyoruz."
						}
					}
				]
			}
		}).replace(/</g, '\\u003c')} />
		<style>
			.custom-cursor {
				position: fixed;
				width: 64px;
				height: 64px;
				background-image: url('/wrench.png');
				background-size: contain;
				background-repeat: no-repeat;
				background-position: center;
				pointer-events: none;
				z-index: 9999;
				transform: translate(-50%, -50%) rotate(0deg);
				opacity: 0;
				transition: opacity 0.2s ease, transform 0.1s ease;
			}
			
			.custom-cursor.visible {
				opacity: 1;
			}
			
			.custom-cursor.rotated {
				transform: translate(-50%, -50%) rotate(15deg);
			}
			
			/* Hide cursor on mobile/touch devices */
			@media (hover: none) and (pointer: coarse) {
				.custom-cursor {
					display: none;
				}
			}
		</style>
	</head>
	<body class="min-h-screen flex flex-col bg-[#eeeeee]">
		<!-- Custom Cursor -->
		<div id="custom-cursor" class="custom-cursor"></div>
		
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />
		<WhatsAppButton />
	</body>
	
	<script>
		// Custom cursor that follows mouse
		(function() {
			const cursor = document.getElementById('custom-cursor');
			if (!cursor) return;
			
			let mouseX = 0;
			let mouseY = 0;
			let cursorX = 0;
			let cursorY = 0;
			
			// Update cursor position with minimal latency
			function updateCursor() {
				const cursorElement = document.getElementById('custom-cursor');
				if (!cursorElement) return;
				
				const dx = mouseX - cursorX;
				const dy = mouseY - cursorY;
				
				// Very fast cursor following - higher interpolation for minimal latency
				cursorX += dx * 0.85;
				cursorY += dy * 0.85;
				
				// Update position - CSS handles transform (centering + rotation)
				cursorElement.style.left = cursorX + 'px';
				cursorElement.style.top = cursorY + 'px';
				
				requestAnimationFrame(updateCursor);
			}
			
			// Track mouse movement
			document.addEventListener('mousemove', (e) => {
				mouseX = e.clientX;
				mouseY = e.clientY;
				
				if (cursor && !cursor.classList.contains('visible')) {
					cursor.classList.add('visible');
				}
			});
			
			// Rotate wrench on mousedown
			document.addEventListener('mousedown', () => {
				if (cursor) {
					cursor.classList.add('rotated');
				}
			});
			
			// Rotate wrench back on mouseup
			document.addEventListener('mouseup', () => {
				if (cursor) {
					cursor.classList.remove('rotated');
				}
			});
			
			// Hide cursor when mouse leaves window
			document.addEventListener('mouseleave', () => {
				if (cursor) {
					cursor.classList.remove('visible');
					cursor.classList.remove('rotated');
				}
			});
			
			// Show cursor when mouse enters window
			document.addEventListener('mouseenter', () => {
				if (cursor) {
					cursor.classList.add('visible');
				}
			});
			
			// Start animation loop
			updateCursor();
		})();
	</script>
</html>
