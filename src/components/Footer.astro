---

<footer class="bg-[#000000] text-[#eeeeee]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Logo Section -->
      <div class="space-y-4 text-center md:text-left">
        <h2 class="text-2xl font-bold text-[#fad000]">
          renazteknik.com
        </h2>
        <p class="text-sm text-[#b7b7b7] leading-relaxed">
          Profesyonel mutfak, banyo ve WC tamirat tadilat hizmetleri. Güvenilir çözümler, kaliteli işçilik.
        </p>
      </div>

      <!-- Contact Information -->
      <div class="space-y-4 text-center md:text-left">
        <h3 class="text-lg font-semibold text-[#fad000] mb-4 uppercase tracking-wide">İletişim Bilgileri</h3>
        <div class="space-y-3">
          <div class="flex items-start space-x-3">
            <svg
              class="w-5 h-5 text-[#fad000] mt-0.5 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              />
            </svg>
            <div>
              <p class="text-sm font-medium text-[#b7b7b7] uppercase">Telefon</p>
              <a
                href="tel:05346706294"
                class="text-[#fad000] hover:text-[#eeeeee] transition-colors font-semibold text-base"
              >
                0534 670 62 94
              </a>
            </div>
          </div>

          <div class="flex items-start space-x-3">
            <svg
              class="w-5 h-5 text-[#fad000] mt-0.5 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
            <div>
              <p class="text-sm font-medium text-[#b7b7b7] uppercase">Konum</p>
              <p class="text-[#eeeeee] leading-relaxed">
                ZAFER MAH. INCE SK. BIRLIK APARTMANI NO: 56 A IÇ KAPI NO: 1 ILKADIM/SAMSUN
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="space-y-4 text-center md:text-left">
        <h3 class="text-lg font-semibold text-[#fad000] mb-4 uppercase tracking-wide">Hızlı Linkler</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="#tadilat"
              class="text-[#b7b7b7] hover:text-[#fad000] transition-colors text-sm"
            >
              Mutfak/Banyo/WC Tamirat
            </a>
          </li>
          <li>
            <a
              href="#kacak-tespiti"
              class="text-[#b7b7b7] hover:text-[#fad000] transition-colors text-sm"
            >
              Su Kaçak Tespiti
            </a>
          </li>
          <li>
            <a
              href="#kanal-goruntuleme"
              class="text-[#b7b7b7] hover:text-[#fad000] transition-colors text-sm"
            >
              Kanal Görüntüleme
            </a>
          </li>
          <li>
            <a
              href="#iletisim"
              class="text-[#b7b7b7] hover:text-[#fad000] transition-colors text-sm"
            >
              İletişim
            </a>
          </li>
          <li>
            <a
              href="#hakkimizda"
              class="text-[#b7b7b7] hover:text-[#fad000] transition-colors text-sm"
            >
              Hakkımızda
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-8 pt-8 border-t border-[#b7b7b7]">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-sm text-[#b7b7b7]">
          © 2025 renazteknik.com. Tüm hakları saklıdır.
        </p>
        <p class="text-sm text-[#b7b7b7]">
          Profesyonel hizmet, güvenilir çözümler
        </p>
      </div>
    </div>
  </div>
</footer>

