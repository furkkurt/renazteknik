---
import bgImage from '../assets/bg3.jpg';
---

<section class="relative w-full h-[500px] sm:h-[600px] lg:h-[700px] overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <img
      src={bgImage.src}
      alt="Sıhhi Tesisat Background"
      class="w-full h-full object-cover blur-xs md:blur-sm"
    />
    <!-- Black Overlay - Lighter on mobile -->
    <div class="absolute inset-0 bg-black/30 md:bg-black/40"></div>
    <!-- Top and Bottom Fade to Black - Shorter gradients -->
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 15%, transparent 30%, transparent 70%, rgba(0,0,0,0.5) 85%, rgba(0,0,0,0.9) 100%);"></div>
  </div>

  <!-- Content - Left Aligned -->
  <div class="relative z-10 h-full flex items-center">
    <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto md:mx-0 hero-content-left text-center md:text-left">
        <!-- First Section -->
        <div class="mb-6 sm:mb-8">
          <a href="/sihhi-tesisat">
            <h2 class="text-3xl sm:text-4xl lg:text-6xl font-bold text-white mb-3 sm:mb-4 leading-tight hover:text-[#fad000] transition-colors duration-200 cursor-pointer" style="font-family: 'Roboto Condensed', sans-serif;">
              SIHHİ TESİSAT
            </h2>
          </a>
          <div class="h-1 w-24 bg-[#fad000] mb-4 sm:mb-6 mx-auto md:mx-0"></div>
          <p class="text-base sm:text-lg lg:text-xl text-white leading-relaxed px-2 sm:px-0" style="font-family: 'Roboto Condensed', sans-serif;">
            Renaz teknik olarak, sıhhi tesisat konusunda müşterilerimize hijyenik, güvenli ve işlevsel sıhhi tesisat çözümleri sunmaktayız.
          </p>
        </div>

        <!-- Second Section -->
        <div>
          <p>
            <h3 class="text-md sm:text-xl lg:text-3xl font-bold text-white mb-3 sm:mb-4 leading-tight" style="font-family: 'Roboto Condensed', sans-serif;">
              ANAHTAR TESLİM BANYO TADİLATI NEDİR ?
            </h3>
          </p>
          <div class="h-1 w-16 bg-[#fad000] mb-4 sm:mb-6 mx-auto md:mx-0"></div>
          <p class="text-base sm:text-lg lg:text-xl text-white leading-relaxed px-2 sm:px-0" style="font-family: 'Roboto Condensed', sans-serif;">
            Banyo tuvalet tadilatı yaptırırken A'dan Z'ye tüm işlemlerin tamamlanarak banyonun eksiksiz bir şekilde alıcıya teslim edilmesine anahtar teslim banyo yenileme denir. Alıcı, tüm işlemlerin yapılmasını ve ek masraf yapmamayı tercih ediyorsa bu yöntemi kullanır.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

