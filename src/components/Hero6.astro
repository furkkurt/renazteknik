---
import bgImage from '../assets/bg6.jpg';
---

<section class="relative w-full h-[500px] sm:h-[600px] lg:h-[700px] overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <img
      src={bgImage.src}
      alt="Kanal Görüntüleme Background"
      class="w-full h-full object-cover blur-xs md:blur-sm"
    />
    <!-- Black Overlay - Lighter on mobile -->
    <div class="absolute inset-0 bg-black/30 md:bg-black/40"></div>
    <!-- Top and Bottom Fade to Black - Shorter gradients -->
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.5) 15%, transparent 30%, transparent 70%, rgba(0,0,0,0.5) 85%, rgba(0,0,0,0.9) 100%);"></div>
  </div>

  <!-- Content - Right Aligned -->
  <div class="relative z-10 h-full flex items-center">
    <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8">
      <div class="w-full flex justify-end">
        <div class="max-w-2xl w-full md:w-auto hero-content-right text-center md:text-right">
        <h2 class="text-3xl sm:text-4xl lg:text-6xl font-bold text-white mb-4 sm:mb-6 leading-tight" style="font-family: 'Roboto Condensed', sans-serif;">
          KANAL<br />GÖRÜNTÜLEME
        </h2>
        <div class="h-1 w-24 bg-[#fad000] mb-6 sm:mb-8 mx-auto md:ml-auto"></div>
        <p class="text-base sm:text-lg lg:text-xl text-white leading-relaxed px-2 sm:px-0" style="font-family: 'Roboto Condensed', sans-serif;">
          Kameralı kanal açma cihazları ile kanalizasyon sistemini tıkayan cisim önce kamera ile tespit edilir. Daha sonra bu cihazın ucuna mesafeye ve cisme göre özel bir aparat takılır. Gider açma işlemi bu şekilde başlatılır. Duruma göre cismi parçalayarak çıkartır, ya da özel robot sayesinde tıkanan yerde ki yabancı cisim çekilerek dışarı atılır.
        </p>
      </div>
    </div>
  </div>
</section>

